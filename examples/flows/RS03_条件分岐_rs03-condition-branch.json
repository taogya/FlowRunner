{
  "id": "rs03-condition-branch",
  "name": "RS03 条件分岐",
  "description": "RSST: Conditionノードのtrue/falseポート分岐を検証。expression評価結果に応じたルーティング",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "comment",
      "type": "comment",
      "label": "検証ポイント",
      "enabled": true,
      "position": {
        "x": 0,
        "y": 0
      },
      "settings": {
        "comment": "1. expression がtrueの場合 trueポートに出力\n2. expression がfalseの場合 falseポートに出力\n3. 入力データが条件式内で input として参照できる"
      }
    },
    {
      "id": "trigger",
      "type": "trigger",
      "label": "開始",
      "enabled": true,
      "position": {
        "x": 0,
        "y": 200
      },
      "settings": {}
    },
    {
      "id": "cmd",
      "type": "command",
      "label": "テストデータ生成",
      "enabled": true,
      "position": {
        "x": 200,
        "y": 200
      },
      "settings": {
        "command": "echo test_value"
      }
    },
    {
      "id": "cond",
      "type": "condition",
      "label": "空文字チェック",
      "enabled": true,
      "position": {
        "x": 450,
        "y": 200
      },
      "settings": {
        "expression": "input && input.length > 0"
      }
    },
    {
      "id": "log_true",
      "type": "log",
      "label": "TRUE分岐",
      "enabled": true,
      "position": {
        "x": 700,
        "y": 120
      },
      "settings": {
        "message": "TRUE: {{input}}",
        "level": "info"
      }
    },
    {
      "id": "log_false",
      "type": "log",
      "label": "FALSE分岐",
      "enabled": true,
      "position": {
        "x": 700,
        "y": 280
      },
      "settings": {
        "message": "FALSE: {{input}}",
        "level": "warn"
      }
    }
  ],
  "edges": [
    {
      "id": "e1",
      "sourceNodeId": "trigger",
