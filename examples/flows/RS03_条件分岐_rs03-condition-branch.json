      "targetNodeId": "cmd",
      "targetPortId": "in"
    },
    {
      "id": "e2",
      "sourceNodeId": "cmd",
      "sourcePortId": "stdout",
      "targetNodeId": "cond",
      "targetPortId": "in"
    },
    {
      "id": "e3",
      "sourceNodeId": "cond",
      "sourcePortId": "true",
      "targetNodeId": "log_true",
      "targetPortId": "in"
    },
    {
