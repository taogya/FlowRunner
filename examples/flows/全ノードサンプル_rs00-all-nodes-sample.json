{
  "id": "rs00-all-nodes-sample",
  "name": "全ノードサンプル",
  "description": "全13種ビルトインノードを1フローに配置。Commandのstdout/stderr、Condition/Loop/TryCatch/Parallelの分岐ポート、およびAI/File/HTTP/SubFlowの依存ノードをまとめて確認するサンプル",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "comment",
      "type": "comment",
      "label": "検証ポイント",
      "enabled": true,
      "position": {
        "x": 0,
        "y": 0
      },
      "settings": {
        "comment": "全13種ビルトインノードの配置サンプルです。\n- Command は stdout / stderr の両出力を表示\n- Condition / Loop / TryCatch / Parallel は複数ポート表示を確認\n- AI / File / HTTP / SubFlow は環境依存のため disabled で同梱"
      }
    },
    {
      "id": "trigger",
      "type": "trigger",
      "label": "手動トリガー",
      "enabled": true,
      "position": {
        "x": 40,
        "y": 220
      },
      "settings": {
        "triggerType": "manual"
      }
    },
    {
      "id": "cmd",
      "type": "command",
      "label": "標準出力と標準エラー",
      "enabled": true,
      "position": {
        "x": 320,
        "y": 90
      },
      "settings": {
        "command": "echo STDOUT_DATA; echo STDERR_DATA >&2"
      }
    },
    {
      "id": "log-stdout",
      "type": "log",
      "label": "stdoutログ",
      "enabled": true,
      "position": {
        "x": 620,
        "y": 60
      },
      "settings": {
        "message": "stdout: {{input}}",
        "level": "info"
      }
    },
    {
      "id": "log-stderr",
      "type": "log",
      "label": "stderrログ",
      "enabled": true,
      "position": {
        "x": 620,
        "y": 140
      },
      "settings": {
        "message": "stderr: {{input}}",
        "level": "warn"
      }
    },
    {
      "id": "file",
      "type": "file",
      "label": "ファイル(read)",
      "enabled": false,
      "position": {
        "x": 900,
        "y": 60
      },
      "settings": {
        "operation": "read",
        "path": "./README.md",
        "encoding": "utf-8"
      }
    },
    {
      "id": "cond",
      "type": "condition",
      "label": "条件分岐",
      "enabled": true,
      "position": {
        "x": 320,
        "y": 270
      },
      "settings": {
        "expression": "input !== null"
      }
    },
    {
      "id": "transform",
