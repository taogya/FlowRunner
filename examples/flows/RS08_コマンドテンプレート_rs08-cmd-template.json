      "position": {
        "x": 0,
        "y": 0
      },
      "settings": {
        "comment": "1. Command設定のcommandフィールドで{{input}}テンプレート展開\n2. 前段ノードの出力がコマンド文字列に埋め込まれる\n3. cwd, shell, env, timeout設定が動作する"
      }
    },
    {
      "id": "trigger",
      "type": "trigger",
      "label": "開始",
      "enabled": true,
      "position": {
        "x": 0,
        "y": 200
      },
      "settings": {}
    },
    {
      "id": "cmd1",
      "type": "command",
      "label": "ホスト名取得",
      "enabled": true,
      "position": {
        "x": 250,
        "y": 200
      },
      "settings": {
        "command": "hostname"
      }
    },
    {
      "id": "cmd2",
      "type": "command",
      "label": "テンプレート展開",
      "enabled": true,
      "position": {
        "x": 500,
        "y": 200
      },
      "settings": {
        "command": "echo \"ホスト名は {{input}} です\"",
        "shell": "zsh"
      }
    },
    {
      "id": "cmd3",
      "type": "command",
