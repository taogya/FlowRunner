      "enabled": true,
      "position": {
        "x": 750,
        "y": 200
      },
      "settings": {
        "command": "echo $MY_VAR",
        "env": {
          "MY_VAR": "custom_value"
        }
      }
    },
    {
      "id": "log1",
      "type": "log",
      "label": "テンプレ結果",
